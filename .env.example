# Copy to `.env` and fill in real values. `.env` is gitignored.
# On Vercel, also set these in Project → Settings → Environment Variables.
#
# The registration form posts to /api/register, which forwards the lead to:
#   1. Skyguru CRM (https://skyguru.ai/api/v1/public/leads) — public, no auth.
#   2. Brevo (https://api.brevo.com/v3/contacts) — adds the contact to a list.

# --- Skyguru CRM (OPTIONAL overrides — leave unset to use defaults) ---
# CRM_ENDPOINT=
# SKYGURU_API_KEY=

# --- Brevo (REQUIRED for the email-list sync) ---
BREVO_API_KEY=
BREVO_LIST_ID=10
