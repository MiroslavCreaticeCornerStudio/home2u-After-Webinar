# Copy to `.env` and fill in real values. `.env` is gitignored.
# On Vercel, also set these in Project → Settings → Environment Variables.

# Brevo (Sendinblue) — server-side only. NEVER expose client-side or commit.
BREVO_API_KEY=
BREVO_LIST_ID=4

# Skyguru CRM — OPTIONAL. Leave unset to use the default public endpoint
# (https://skyguru.ai/api/v1/public/leads). The lead forward is best-effort
# and never blocks the Brevo capture.
# CRM_ENDPOINT=
# SKYGURU_API_KEY=
