# Copy to `.env` and fill in real values. `.env` is gitignored.
# On Vercel, also set these in Project → Settings → Environment Variables.
#
# The registration form posts to /api/register → Skyguru CRM
# (https://skyguru.ai/api/v1/public/leads). The public endpoint needs NO auth,
# so these are OPTIONAL overrides — leave unset to use the defaults.

# CRM_ENDPOINT=
# SKYGURU_API_KEY=
