---
// Hero section — nav bar + display headline + glass CTA card + info bar.
// Figma node 2856:184.
const navLinks = [
  { label: "За кого е подходящо", href: "#target-audience" },
  { label: "Защо да се запишеш", href: "#why-join" },
  { label: "Какво включва", href: "#whats-included" },
  { label: "За лектора", href: "#speaker" },
  { label: "Цена", href: "#pricing" },
  { label: "Въпроси", href: "#faq" },
];

const info = [
  { icon: "icon-calendar.svg", label: "Дати:", value: "Понеделник – Петък" },
  { icon: "icon-clock.svg", label: "Час:", value: "18:00 – 19:30 ч." },
  { icon: "icon-mappin.svg", label: "Място:", value: "Hilton Sofia" },
  { icon: "icon-user.svg", label: "Лектор:", value: "Ралица Ценова" },
];
---

<section class="hero">
  <!-- Nav -->
  <header class="hero__nav">
    <div class="hero__nav-inner container container--padded">
      <a class="hero__logo" href="#" aria-label="Home2U">
        <img src="/assets/images/logo-home2u-icon.svg" alt="" width="35" height="35" class="hero__logo-icon" />
        <img src="/assets/images/logo-home2u-text.svg" alt="Home2U" width="145" height="35" class="hero__logo-text" />
      </a>

      <nav class="hero__nav-links" aria-label="Основна навигация">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>

      <a href="#register" class="btn btn--outline hero__nav-cta">Запиши се сега</a>

      <button
        type="button"
        class="hero__burger"
        aria-label="Меню"
        aria-expanded="false"
        aria-controls="hero-mobile-menu"
      >
        <span class="hero__burger-bar"></span>
        <span class="hero__burger-bar"></span>
        <span class="hero__burger-bar"></span>
      </button>
    </div>

    <nav id="hero-mobile-menu" class="hero__mobile-menu" aria-label="Мобилна навигация" hidden>
      <div class="hero__mobile-menu-inner container container--padded">
        {navLinks.map((l) => <a href={l.href} class="hero__mobile-link">{l.label}</a>)}
        <a href="#register" class="btn btn--primary hero__mobile-cta">Запиши се сега</a>
      </div>
    </nav>
  </header>

  <!-- Hero body -->
  <div class="hero__body container container--padded">
    <h1 class="hero__headline">
      <span class="hero__hl-line hero__hl-line--top">Как да правим</span>
      <span class="hero__hl-big hero__hl-big--first">сделки</span>
      <span class="hero__hl-divider">
        <span class="hero__hl-rule" aria-hidden="true"></span>
        <span class="hero__hl-za">за</span>
      </span>
      <span class="hero__hl-big hero__hl-big--second">милиони</span>
      <span class="hero__hl-line hero__hl-line--bottom">от брокерство</span>
    </h1>

    <div class="hero__card">
      <div class="hero__card-content">
        <hr class="accent-line" />
        <p class="hero__card-desc">
          Устойчивият успех в брокерството не идва случайно. В този курс ще научиш
          как се подреждат клиентите, процесите и сделките от човек, който е стигал
          до рекордни резултати в брокерството.
        </p>
      </div>
      <a href="#register" class="btn btn--primary hero__card-cta">Запази своето място</a>
    </div>
  </div>

  <!-- Info bar -->
  <div class="hero__info container container--padded">
    {
      info.map((item) => (
        <div class="hero__info-card">
          <img src={`/assets/images/${item.icon}`} alt="" width="28" height="28" class="hero__info-icon" />
          <div class="hero__info-text">
            <span class="hero__info-label">{item.label}</span>
            <span class="hero__info-value">{item.value}</span>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Speaker cutout, centered between the headline and the card -->
  <img
    class="hero__speaker"
    src="/assets/images/hero-speaker.webp"
    alt="Ралица Ценова"
    width="900"
    height="1301"
    fetchpriority="high"
  />
</section>

<script>
  // Mobile hamburger menu toggle (≤991px).
  const burger = document.querySelector<HTMLButtonElement>(".hero__burger");
  const menu = document.getElementById("hero-mobile-menu");

  if (burger && menu) {
    const closeMenu = () => {
      burger.setAttribute("aria-expanded", "false");
      burger.classList.remove("is-open");
      menu.hidden = true;
    };
    const openMenu = () => {
      burger.setAttribute("aria-expanded", "true");
      burger.classList.add("is-open");
      menu.hidden = false;
    };

    burger.addEventListener("click", () => {
      const isOpen = burger.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    // Close after tapping a link.
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && burger.getAttribute("aria-expanded") === "true") {
        closeMenu();
        burger.focus();
      }
    });
  }
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    padding-bottom: 5em;
    /* Webinar-audience photo backdrop with a soft white wash on the left
       so the dark headline stays legible; photo shows through on the right. */
    background-image:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.92) 0%,
        rgba(255, 255, 255, 0.6) 30%,
        rgba(255, 255, 255, 0.2) 55%,
        rgba(255, 255, 255, 0) 80%
      ),
      url("/assets/images/hero-bg.jpg");
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
  }

  /* Keep the headline, card and info bar above the speaker cutout. */
  .hero__nav,
  .hero__body,
  .hero__info {
    position: relative;
    z-index: 2;
  }

  /* Speaker cutout — centered, standing above the info bar, behind the content. */
  .hero__speaker {
    z-index: 2;
    pointer-events: none;
    user-select: none;
    width: auto;
    height: 40em;
    position: absolute;
    bottom: 0;
    left: 46%;
    transform: translate(-50%);
  }

  /* Nav */
  .hero__nav {
    width: 100%;
  }
  .hero__nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.375em; /* 70px */
    gap: 2em;
  }
  .hero__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65em;
    flex-shrink: 0;
  }
  .hero__logo-icon {
    width: 2.19em;
    height: 2.19em;
  }
  .hero__logo-text {
    width: auto;
    height: 2.19em;
  }
  .hero__nav-links {
    display: flex;
    align-items: center;
    gap: 1.5em; /* 24px */
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.875em; /* 14px */
    line-height: 1.4;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .hero__nav-links a:hover {
    color: var(--color-primary);
  }
  .hero__nav-cta {
    flex-shrink: 0;
    font-size: 1em;
  }

  /* Hamburger button — hidden on desktop, shown ≤991px. */
  .hero__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 0.3125em; /* 5px */
    width: 2.875em; /* 46px — rounded square */
    height: 2.875em;
    padding: 0;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm);
    background-color: transparent;
    cursor: pointer;
    flex-shrink: 0;
  }
  .hero__burger-bar {
    display: block;
    width: 1.375em; /* 22px */
    height: 2px;
    margin-inline: auto;
    background-color: var(--color-primary);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }
  .hero__burger.is-open .hero__burger-bar:nth-child(1) {
    transform: translateY(0.4375em) rotate(45deg);
  }
  .hero__burger.is-open .hero__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .hero__burger.is-open .hero__burger-bar:nth-child(3) {
    transform: translateY(-0.4375em) rotate(-45deg);
  }

  /* Mobile dropdown menu — only rendered ≤991px (hidden attribute on desktop). */
  .hero__mobile-menu {
    display: none;
  }
  .hero__mobile-menu-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25em; /* 20px */
    padding-top: 1.5em;
    padding-bottom: 1.5em;
  }
  .hero__mobile-link {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.125em; /* 18px */
    line-height: 1.4;
    color: var(--color-text-primary);
  }
  .hero__mobile-link:hover {
    color: var(--color-primary);
  }
  .hero__mobile-cta {
    margin-top: 0.5em;
    width: 100%;
  }

  /* Hero body */
  .hero__body {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
    padding-top: 6.06em; /* ~97px above content (nav 70 + 167-70) */
  }

  .hero__headline {
    font-family: var(--font-heading);
    font-size: 1em; /* neutralize browser h1 default so child em values stay accurate */
    font-weight: 600;
    margin: 0;
    padding-top: 1.5em;
  }
  .hero__hl-line {
    display: block;
    font-weight: 500;
    font-size: 2.25em; /* 36px */
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .hero__hl-line--bottom {
    padding-left: 1.55em; /* 56px relative to 36px */
  }
  .hero__hl-big {
    display: block;
    font-weight: 600;
    color: var(--color-primary);
  }
  .hero__hl-big--first {
    font-size: 5.5em; /* ~88px */
    line-height: 1.1;
    text-align: center;
    width: 6.09em; /* 335px / 55 */
  }
  .hero__hl-big--second {
    font-size: 5.15em; /* ~82px */
    line-height: 0.95;
    padding-left: 0.68em; /* 56px relative to 82px */
  }
  .hero__hl-divider {
    display: flex;
    align-items: center;
    gap: 1.25em;
    width: 20.94em; /* 335px-ish row */
    margin: 0.1em 0;
  }
  .hero__hl-rule {
    flex: 1 1 auto;
    height: 2px;
    background-color: var(--color-primary);
  }
  .hero__hl-za {
    font-size: 2.28em; /* 36.5px */
    line-height: 1.3;
    color: var(--color-primary);
  }

  /* Glass card */
  .hero__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 36.44em; /* 583px */
    flex-shrink: 0;
    padding: 4em 4em 4.5em;
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: var(--radius-lg);
    background-image: linear-gradient(
      to left,
      rgba(255, 255, 255, 0.5),
      rgba(255, 255, 255, 0.3)
    );
    -webkit-backdrop-filter: blur(12.7px);
    backdrop-filter: blur(12.7px);
    gap: 2.25em;
  }
  .hero__card-content {
    display: flex;
    flex-direction: column;
    gap: 1.125em;
  }
  .hero__card-desc {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    line-height: 1.5;
    color: var(--color-text-secondary);
  }
  .hero__card-cta {
    align-self: flex-start;
  }

  /* Info bar */
  .hero__info {
    display: flex;
    gap: 0.8125em; /* 13px */
    margin-top: 3.06em; /* ~49px */
    z-index: 4; /* keep info cards above the speaker cutout */
  }
  .hero__info-card {
    display: flex;
    align-items: center;
    gap: 0.75em;
    flex: 1 1 0;
    min-width: 0;
    padding: 1em 1.25em;
    background-color: var(--color-bg-card);
    border-radius: var(--radius-sm);
  }
  .hero__info-icon {
    width: 1.75em;
    height: 1.75em;
    flex-shrink: 0;
  }
  .hero__info-text {
    display: flex;
    flex-direction: column;
    line-height: 1.5;
  }
  .hero__info-label {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    color: var(--color-text-secondary);
  }
  .hero__info-value {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1em; /* 16px */
    color: var(--color-text-primary);
  }

  /* Tablet */
  @media (max-width: 991px) {
    .hero__nav-links {
      display: none;
    }
    /* Desktop nav CTA hidden; hamburger takes over. */
    .hero__nav-cta {
      display: none;
    }
    .hero__burger {
      display: flex;
    }
    /* The mobile menu becomes a normal block when open. Visibility is gated by
       the `hidden` attribute toggled in the script; `:not([hidden])` keeps the
       class rule from overriding the attribute's display:none. */
    .hero__mobile-menu:not([hidden]) {
      display: block;
    }
    .hero__nav-inner {
      height: auto;
      padding-top: 1em;
      padding-bottom: 1em;
    }

    .hero__body {
      flex-direction: column;
      gap: 2.5em;
      padding-top: 3em;
    }
    .hero__card {
      width: 100%;
    }
    .hero__hl-big--first {
      width: auto;
      text-align: left;
    }
    .hero__hl-divider {
      width: 100%;
      max-width: 22em;
    }
  }

  /* Mobile landscape — full mobile redesign per Figma 360px frame */
  @media (max-width: 767px) {
    /* Reorder children: nav → body (headline+desc+CTA) → speaker → info.
       The section becomes a flex column so the absolutely-positioned speaker
       can be pulled into normal flow between the body and the info bar. */
    .hero {
      display: flex;
      flex-direction: column;
      padding-bottom: 0;
    }
    .hero__nav {
      order: 1;
    }
    .hero__body {
      order: 2;
      padding-top: 2em;
      gap: 1.5em; /* 24px between headline and text block */
    }
    .hero__hl-line--bottom {
      padding-left: 1em;
    }
    .hero__speaker {
      order: 3;
    }
    .hero__info {
      order: 4;
    }

    /* Description reads as a normal paragraph — strip the glass card chrome. */
    .hero__card {
      padding: 0;
      border: 0;
      border-radius: 0;
      background-image: none;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      gap: 1.5em; /* 24px between description and CTA */
    }
    .hero__card-content {
      gap: 0.75em;
    }
    .hero__card-content .accent-line {
      display: none;
    }
    .hero__card-desc {
      font-size: 0.875em; /* 14px */
      color: var(--color-text-secondary);
    }

    /* Full-width gradient CTA. */
    .hero__card-cta {
      align-self: stretch;
      width: 100%;
      padding-inline: 1.5em;
    }

    /* Speaker cutout — pulled into normal flow, full-width, centered, large. */
    .hero__speaker {
      display: block;
      position: static;
      transform: none;
      left: auto;
      bottom: auto;
      width: 100%;
      max-width: 26em;
      height: auto;
      margin: 1.5em auto -1em;
    }

    /* Info rows — full-width single column. */
    .hero__info {
      flex-direction: column;
      flex-wrap: nowrap;
      gap: 0.5em; /* 8px */
      margin-top: 1.5em;
      padding-bottom: 3.5em; /* breathing room at section bottom */
    }
    .hero__info-card {
      flex: 1 1 auto;
      width: 100%;
      gap: 0.5em; /* 8px */
      padding: 0.5em; /* 8px */
    }
    .hero__info-icon {
      width: 1.75em; /* 28px */
      height: 1.75em;
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .hero__hl-big--first {
      font-size: 4em;
    }
    .hero__hl-big--second {
      font-size: 3.75em;
    }
    .hero__info-card {
      flex: 1 1 auto;
    }
  }
</style>
