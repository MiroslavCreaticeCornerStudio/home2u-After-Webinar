---
// Footer section — logo, course nav, contacts, and crimson legal bar.
// Figma node 2856:612.
const courseLinks = [
  { label: "За кого е подходящо", href: "#target-audience" },
  { label: "Защо да се запишеш", href: "#why-join" },
  { label: "Какво включва", href: "#whats-included" },
  { label: "За лектора", href: "#speaker" },
  { label: "Цена", href: "#pricing" },
  { label: "Въпроси", href: "#faq" },
];
---

<footer class="footer">
  <div class="footer__inner container container--padded">
    <!-- Logo -->
    <a class="footer__logo" href="#" aria-label="Home2U">
      <img
        src="/assets/images/footer-logo-icon.svg"
        alt=""
        width="31"
        height="31"
        class="footer__logo-icon"
      />
      <img
        src="/assets/images/footer-logo-text.svg"
        alt="Home2U"
        width="129"
        height="31"
        class="footer__logo-text"
      />
    </a>

    <!-- Course nav -->
    <nav class="footer__col footer__col--course" aria-label="Курс">
      <h2 class="footer__title">Курс</h2>
      <ul class="footer__links">
        {courseLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Contacts -->
    <div class="footer__col footer__col--contacts">
      <h2 class="footer__title">Контакти</h2>
      <ul class="footer__contacts">
        <li class="footer__contact">
          <img
            src="/assets/images/icon-phone.svg"
            alt=""
            width="14"
            height="14"
            class="footer__contact-icon"
          />
          <a href="tel:+35988788333222">+359 887 88333222</a>
        </li>
        <li class="footer__contact">
          <img
            src="/assets/images/icon-email.svg"
            alt=""
            width="16"
            height="14"
            class="footer__contact-icon"
          />
          <a href="mailto:info@home2u.com">info@home2u.com</a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Legal bar -->
  <div class="footer__bar">
    <div class="footer__bar-inner container container--padded">
      <div class="footer__legal">
        <a href="#">Защита на личните данни</a>
        <span class="footer__legal-sep" aria-hidden="true">|</span>
        <a href="#">Информация по ЗЗЛПСПООИН</a>
      </div>
      <p class="footer__copyright">“Home2U Недвижими Имоти” 2026 година</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
    padding-top: 4em; /* 64px */
    padding-bottom: 4em;
  }

  /* Logo */
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.636em; /* ~10px between mark and wordmark */
    flex-shrink: 0;
  }
  .footer__logo-icon {
    width: 1.95em; /* 31.16px */
    height: 1.95em;
  }
  .footer__logo-text {
    width: 8.04em; /* 128.64px */
    height: 1.93em; /* 30.82px */
  }

  /* Columns */
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
  }
  .footer__col--course {
    flex: 0 1 auto;
    max-width: 29.25em; /* ~468px nav width */
  }
  .footer__col--contacts {
    width: 15.8125em; /* 253px */
    flex-shrink: 0;
  }

  /* Column title */
  .footer__title {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    line-height: 1.3;
    color: var(--color-text-primary);
    padding-bottom: 0.5em; /* ~9px */
    border-bottom: 1px solid #c6c6c6;
  }

  /* Course links */
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5em; /* 24px */
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.4;
    color: var(--color-text-primary);
  }
  .footer__links a {
    white-space: nowrap;
  }
  .footer__links a:hover {
    color: var(--color-primary);
  }

  /* Contacts */
  .footer__contacts {
    display: flex;
    flex-direction: column;
    gap: 1.125em; /* ~17.98px */
  }
  .footer__contact {
    display: flex;
    align-items: center;
    gap: 0.843em; /* ~13.49px */
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.3;
    color: var(--color-text-secondary);
  }
  .footer__contact-icon {
    width: 1em; /* 16px max icon box */
    height: 0.875em;
    flex-shrink: 0;
  }
  .footer__contact a:hover {
    color: var(--color-primary);
  }

  /* Legal bar */
  .footer__bar {
    width: 100%;
    background-color: var(--color-primary);
  }
  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
    min-height: 2.75em; /* 44px */
    padding-top: 0.8125em; /* 13px */
    padding-bottom: 0.8125em;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.3;
    color: var(--color-text-white);
  }
  .footer__legal {
    display: flex;
    align-items: center;
    gap: 1em; /* 16px */
  }
  .footer__legal a {
    text-decoration: underline;
  }
  .footer__legal a:hover {
    opacity: 0.85;
  }
  .footer__copyright {
    white-space: nowrap;
  }

  /* Tablet */
  @media (max-width: 991px) {
    .footer__inner {
      flex-wrap: wrap;
      gap: 2.5em;
    }
    .footer__col--course {
      flex: 1 1 100%;
      max-width: none;
    }
    .footer__col--contacts {
      flex: 1 1 auto;
      width: auto;
    }
  }

  /* Mobile landscape */
  @media (max-width: 767px) {
    .footer__inner {
      flex-direction: column;
      gap: 2.5em;
    }
    .footer__bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75em;
    }
    .footer__copyright {
      white-space: normal;
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .footer__legal {
      flex-wrap: wrap;
      gap: 0.5em 0.75em;
    }
  }
</style>
