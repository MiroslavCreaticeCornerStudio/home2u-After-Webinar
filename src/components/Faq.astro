---
// FAQ section — accordion of Q&A pairs built with native <details>/<summary>.
// Figma node 2856:521 ("FAQ section").
const faqs = [
  {
    question: "Нужно ли е да имам опит като брокер, за да се запиша?",
    answer:
      "Не. Обучението е подходящо както за хора, които обмислят кариера в недвижимите имоти, така и за брокери, които вече работят в бранша.",
  },
  {
    question: "Къде ще се провежда обучението?",
    answer: "Обучението ще се проведе на живо в Hilton Sofia.",
  },
  {
    question: "Ще има ли онлайн достъп или запис от обучението",
    answer:
      "Не. Обучението ще се проведе само присъствено и няма да бъде достъпно онлайн или на запис.",
  },
  {
    question: "Ще получа ли сертификат след обучението?",
    answer:
      "Да. Всеки успешно преминал обучението участник ще получи сертификат, удостоверяващ участието му в програмата.",
  },
];
---

<section class="faq" id="faq">
  <div class="faq__inner container container--padded">
    <div class="faq__column">
      <header class="faq__header">
        <hr class="accent-line" />
        <h2 class="faq__title">
          Често задавани <span class="faq__title-accent">въпроси</span>
        </h2>
      </header>

      <div class="faq__list">
        {
          faqs.map((item, i) => (
            <details class="faq__item" open={i === 0}>
              <summary class="faq__summary">
                <span class="faq__question">{item.question}</span>
                <svg
                  class="faq__icon"
                  width="25"
                  height="25"
                  viewBox="0 0 24.7783 24.7783"
                  fill="none"
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M2.53215 16.5813C2.82256 16.8716 3.2164 17.0347 3.62704 17.0347C4.03769 17.0347 4.43152 16.8716 4.72193 16.5813L12.3877 8.91551L20.0535 16.5813C20.3456 16.8634 20.7368 17.0195 21.1428 17.016C21.5489 17.0124 21.9373 16.8496 22.2244 16.5624C22.5116 16.2753 22.6744 15.8869 22.678 15.4808C22.6815 15.0748 22.5254 14.6836 22.2433 14.3915L13.4826 5.63083C13.1922 5.3405 12.7984 5.17741 12.3877 5.17741C11.9771 5.17741 11.5833 5.3405 11.2928 5.63083L2.53215 14.3915C2.24182 14.6819 2.07873 15.0758 2.07873 15.4864C2.07873 15.8971 2.24182 16.2909 2.53215 16.5813Z"
                    fill="currentColor"
                  />
                </svg>
              </summary>
              <div class="faq__answer-wrap">
                <p class="faq__answer">{item.answer}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    width: 100%;
    padding-block: 5em; /* 80px section padding */
  }

  .faq__inner {
    display: flex;
    justify-content: center;
  }

  .faq__column {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.75em; /* 60px */
    width: 100%;
    max-width: 40.8125em; /* 653px content column */
  }

  /* Header */
  .faq__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25em; /* 20px */
  }

  .faq__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2.625em; /* 42px */
    line-height: 1.3;
    color: var(--color-text-primary);
    text-align: center;
  }
  .faq__title-accent {
    color: var(--color-primary);
  }

  /* List */
  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
    width: 100%;
  }

  .faq__item {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
    padding-bottom: 1.5em; /* 24px */
    border-bottom: 1px solid var(--color-border);
    width: 100%;
  }

  /* Question pill (summary) */
  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em; /* 16px */
    width: 100%;
    padding: 1em 1.5em; /* 16px 24px */
    /* Non-token: Figma border-radius 12.682px */
    border-radius: 0.7926em;
    background-color: var(--color-primary);
    cursor: pointer;
    list-style: none;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }
  .faq__summary::-webkit-details-marker {
    display: none;
  }

  .faq__question {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.125em; /* 18px */
    line-height: 1.5; /* 27px / 18px */
    color: var(--color-text-white);
  }

  .faq__icon {
    flex-shrink: 0;
    width: 1.5486em; /* 24.778px */
    height: 1.5486em;
    color: var(--color-text-white);
    /* Closed = chevron points down (Figma flips the up-arrow vertically) */
    transform: scaleY(-1);
    transition: transform var(--transition-base);
  }
  .faq__item[open] .faq__icon {
    /* Open = chevron points up */
    transform: scaleY(1);
  }

  /* Answer */
  .faq__answer-wrap {
    display: flex;
    align-items: flex-start;
    width: 100%;
  }
  .faq__answer {
    flex: 1 1 0;
    min-width: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1em; /* 16px */
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  /* Tablet */
  @media (max-width: 991px) {
    .faq__column {
      max-width: 100%;
    }
  }

  /* Mobile landscape */
  @media (max-width: 767px) {
    .faq__column {
      gap: 2.5em;
    }
    .faq__summary {
      min-height: 2.75em; /* touch target */
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .faq__title {
      font-size: 2em;
    }
    .faq__question {
      font-size: 1em;
    }
  }
</style>
