---
// "What's included" section — Figma node 2723:547 (redesign).
// Title block + 2 cards (row 1), 4 cards (row 2), 3 cards + CTA (row 3).
// All module cards are crimson with a white icon, title and description.
const cards = [
  {
    icon: "wi-psychology.svg",
    title: "Психология на продажбите",
    desc: "Как се подрежда пътят от първия контакт до сделката и кои са основните правила, които държат процеса ясен и професионален.",
  },
  {
    icon: "wi-principles.svg",
    title: "Основни принципи на продажбения процес",
    desc: "Как се подрежда пътят от първия контакт до сделката и кои са основните правила, които държат процеса ясен и професионален.",
  },
  {
    icon: "wi-stages.svg",
    title: "Етапи на търговския процес",
    desc: "Какво се случва на всеки етап от комуникацията с клиента и къде най-често се губят доверие, посока или шанс за сделка.",
  },
  {
    icon: "wi-flow.svg",
    title: "Система за непрекъснат поток за продажби",
    desc: "Как да не разчиташ само на случайни запитвания, а да работиш по начин, който създава повече бъдещи възможности.",
  },
  {
    icon: "wi-seller.svg",
    title: "Как да работим с продавач така че да избират нас",
    desc: "Как да говориш със собственик така, че да разбере стойността ти, да ти има доверие и да избере да работи с теб.",
  },
  {
    icon: "wi-buyer.svg",
    title: "Ефективна работа с купувач",
    desc: "Как да разбереш реалните нужди, мотивация и готовност на купувача, за да не правиш просто огледи, а да водиш процес с посока.",
  },
  {
    icon: "wi-trust.svg",
    title: "Как доверието се превръща в затворена сделка",
    desc: "Как подготовката, комуникацията и правилното водене на процеса стигат до решение.",
  },
  {
    icon: "wi-admin.svg",
    title: "Администрация и документална подготовка:",
    desc: "Какво трябва да знаеш за документите и административните стъпки около сделката, за да работиш по-спокойно и подготвено.",
  },
  {
    icon: "wi-retention.svg",
    title: "Как да работим така, че да нямаме бивши клиенти",
    desc: "Как се изграждат отношения след сделката, така че клиентите да се връщат, да те препоръчват и да останат част от дългосрочния ти бизнес.",
  },
];
---

<section class="whats-included" id="whats-included">
  <div class="whats-included__inner container container--padded">
    <div class="wi__grid">
      <div class="wi__intro">
        <hr class="accent-line" />
        <h2 class="wi__title">Какво включва програмата?</h2>
        <p class="wi__desc">
          В рамките на една седмица ще минем през ключовите теми, които изграждат
          основата на успешното брокерство.
        </p>
      </div>

      {/* On desktop `display:contents` makes these cards direct grid children (grid unchanged). On mobile this becomes the horizontal scroll-snap track. */}
      <div class="wi__track" data-wi-track>
        {
          cards.map((c) => (
            <article class="wi__card">
              <img
                class="wi__card-icon"
                src={`/course/assets/images/${c.icon}`}
                alt=""
                width="56"
                height="56"
                loading="lazy"
              />
              <div class="wi__card-text">
                <h3 class="wi__card-title">{c.title}</h3>
                <p class="wi__card-desc">{c.desc}</p>
              </div>
            </article>
          ))
        }

        <div class="wi__detail">
          <div class="wi__detail-head">
            <hr class="accent-line" />
            <p class="wi__detail-title">Искаш ли постоянен поток от добри възможности?</p>
          </div>
          <a href="#pricing" class="btn btn--primary wi__detail-btn">Запиши се сега</a>
        </div>
      </div>

      {/* Mobile-only carousel arrows — hidden on desktop. */}
      <div class="wi__nav" data-wi-nav>
        <button type="button" class="wi__arrow" data-wi-prev aria-label="Предишна карта">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button type="button" class="wi__arrow" data-wi-next aria-label="Следваща карта">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  // Mobile carousel — arrows scroll the track by one card.
  document.querySelectorAll<HTMLElement>(".whats-included").forEach((section) => {
    const track = section.querySelector<HTMLElement>("[data-wi-track]");
    const prev = section.querySelector<HTMLButtonElement>("[data-wi-prev]");
    const next = section.querySelector<HTMLButtonElement>("[data-wi-next]");
    if (!track || !prev || !next) return;

    const step = () => {
      const card = track.querySelector<HTMLElement>(".wi__card, .wi__detail");
      const gap = parseFloat(getComputedStyle(track).columnGap || "0") || 0;
      const width = card ? card.getBoundingClientRect().width : track.clientWidth * 0.85;
      return width + gap;
    };

    prev.addEventListener("click", () => track.scrollBy({ left: -step(), behavior: "smooth" }));
    next.addEventListener("click", () => track.scrollBy({ left: step(), behavior: "smooth" }));
  });
</script>

<style>
  .whats-included {
    width: 100%;
    padding-block: 5em; /* 80px */
  }

  .wi__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5em; /* 24px */
  }

  /* Track wrapper is transparent to the grid on desktop — cards act as direct grid children. */
  .wi__track {
    display: contents;
  }

  /* Mobile carousel arrows — hidden on desktop/tablet. */
  .wi__nav {
    display: none;
  }

  /* Title block — spans the first two columns of row 1, vertically centered. */
  .wi__intro {
    grid-column: span 2;
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: 1.25em; /* 20px */
    padding-right: 2.5em;
  }
  .wi__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2.625em; /* 42px */
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .wi__desc {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  /* Module card — crimson with white icon + title + description. */
  .wi__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5em;
    min-height: 24.3125em; /* 389px */
    padding: 2em; /* 32px */
    background-color: var(--color-primary);
    border-radius: 1.875em; /* 30px */
    color: var(--color-text-white);
  }
  .wi__card-icon {
    width: 3.5em; /* 56px */
    height: 3.5em;
    flex-shrink: 0;
  }
  .wi__card-text {
    display: flex;
    flex-direction: column;
    gap: 0.5em; /* 8px */
  }
  .wi__card-title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.375em; /* 22px */
    line-height: 1.4;
  }
  .wi__card-desc {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.5;
  }

  /* CTA cell — frosted glass with action title + button. */
  .wi__detail {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.25em; /* 36px */
    min-height: 24.3125em;
    padding: 3em 2em; /* 48px 32px */
    border: 1px solid var(--color-bg-white);
    border-radius: 1.875em;
    background-image: linear-gradient(
      to left,
      rgba(255, 255, 255, 0.7),
      rgba(255, 255, 255, 0.42)
    );
    -webkit-backdrop-filter: blur(15px);
    backdrop-filter: blur(15px);
  }
  .wi__detail-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25em;
    width: 100%;
  }
  .wi__detail-title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.5em; /* 24px */
    line-height: 1.2;
    text-align: center;
    color: var(--color-text-primary);
  }
  .wi__detail-btn {
    width: 100%;
  }

  /* Tablet — 2 columns */
  @media (max-width: 991px) {
    .wi__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .wi__intro {
      grid-column: span 2;
      align-self: start;
      padding-right: 0;
    }
  }

  /* Mobile — intro on top, program cards become a horizontal scroll carousel. */
  @media (max-width: 767px) {
    /* Grid collapses to a single column so the intro and the track stack vertically. */
    .wi__grid {
      grid-template-columns: 1fr;
      gap: 2em; /* 32px between intro and carousel */
    }
    .wi__intro {
      grid-column: span 1;
    }

    /* Track becomes the scrollable, snapping carousel. */
    .wi__track {
      display: flex;
      gap: 1em; /* 16px between cards */
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* Bleed to the section edges so neighbouring cards peek; pad so the first/last card still snap centred. */
      margin-inline: calc(-1 * var(--container-padding));
      padding-inline: var(--container-padding);
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
    }
    .wi__track::-webkit-scrollbar {
      display: none; /* Chrome / Safari */
    }

    .wi__card,
    .wi__detail {
      flex: 0 0 85%;
      max-width: 85%;
      min-height: 0;
      justify-content: flex-start;
      gap: 1.25em;
      scroll-snap-align: center;
    }
    .wi__detail {
      align-items: center;
      justify-content: center;
      padding: 2.5em 1.5em;
    }

    /* Carousel arrows below the track. */
    .wi__nav {
      display: flex;
      justify-content: center;
      gap: 1em; /* 16px */
      margin-top: 2em; /* 32px */
    }
    .wi__arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.625em; /* 42px */
      height: 2.625em;
      border: 1px solid var(--color-primary);
      border-radius: 50%;
      background-color: var(--color-bg-white);
      color: var(--color-primary);
      cursor: pointer;
    }
    .wi__arrow:hover {
      background-color: var(--color-primary);
      color: var(--color-text-white);
    }
  }

  @media (max-width: 479px) {
    .wi__title {
      font-size: 2.125em;
    }
    /* Slightly wider cards on the narrowest screens so copy stays comfortable. */
    .wi__card,
    .wi__detail {
      flex-basis: 88%;
      max-width: 88%;
    }
  }
</style>
