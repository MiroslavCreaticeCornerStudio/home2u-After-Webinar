---
// Final CTA Section — photo background + light pastel gradient overlay,
// event details glass card (left) + registration form (right).
// Figma node 2856:555.
const details = [
  { icon: "icon-finalcta-date.svg", label: "Дати:", value: "Понеделник – Петък" },
  { icon: "icon-finalcta-time.svg", label: "Час:", value: "18:00 – 19:30 ч." },
  { icon: "icon-finalcta-location.svg", label: "Място:", value: "Hilton Sofia" },
];
---

<section class="final-cta" id="register">
  <!-- Background photo (full-width) + gradient overlay -->
  <img
    class="final-cta__bg"
    src="/assets/images/finalcta-background.jpg"
    alt=""
    aria-hidden="true"
    width="1920"
    height="1083"
    loading="lazy"
    decoding="async"
  />
  <span class="final-cta__overlay" aria-hidden="true"></span>

  <div class="final-cta__inner container container--padded">
    <!-- Left: event details card -->
    <div class="final-cta__details-card">
      <div class="final-cta__header">
        <h2 class="final-cta__title">
          Направи<br class="final-cta__title-break" /> първата крачка към сделките за милиони
        </h2>
        <hr class="accent-line final-cta__accent" />
      </div>

      <div class="final-cta__details">
        {
          details.map((item) => (
            <div class="final-cta__detail-row">
              <img
                src={`/assets/images/${item.icon}`}
                alt=""
                width="36"
                height="36"
                class="final-cta__detail-icon"
                loading="lazy"
              />
              <div class="final-cta__detail-text">
                <span class="final-cta__detail-label">{item.label}</span>
                <span class="final-cta__detail-value">{item.value}</span>
              </div>
            </div>
          ))
        }
      </div>

      <div class="final-cta__tickets">
        <span class="final-cta__tickets-tag">Оставащи места</span>
        <span class="final-cta__tickets-number"><span class="final-cta__tickets-digit">10</span></span>
      </div>
    </div>

    <!-- Right: registration form → Brevo + Skyguru CRM (see src/pages/api/register.ts) -->
    <div class="final-cta__form-card">
      <form class="final-cta__form" action="/api/register" method="post" novalidate>
        <div class="final-cta__fields">
          <div class="final-cta__field">
            <label class="final-cta__label" for="final-cta-name">Име*</label>
            <input
              class="final-cta__input"
              id="final-cta-name"
              name="name"
              type="text"
              placeholder="Име"
              autocomplete="name"
              required
              aria-describedby="final-cta-name-error"
            />
            <span class="final-cta__error" id="final-cta-name-error" aria-live="polite"></span>
          </div>

          <div class="final-cta__field">
            <label class="final-cta__label" for="final-cta-phone">Телефон*</label>
            <input
              class="final-cta__input"
              id="final-cta-phone"
              name="phone"
              type="tel"
              placeholder="Телефон"
              autocomplete="tel"
              required
              aria-describedby="final-cta-phone-error"
            />
            <span class="final-cta__error" id="final-cta-phone-error" aria-live="polite"></span>
          </div>

          <div class="final-cta__field">
            <label class="final-cta__label" for="final-cta-email">Имейл*</label>
            <input
              class="final-cta__input"
              id="final-cta-email"
              name="email"
              type="email"
              placeholder="Имейл"
              autocomplete="email"
              required
              aria-describedby="final-cta-email-error"
            />
            <span class="final-cta__error" id="final-cta-email-error" aria-live="polite"></span>
          </div>
        </div>

        <div class="final-cta__consent-section">
          <div class="final-cta__consent">
            <input
              class="final-cta__checkbox"
              id="final-cta-consent"
              name="consent"
              type="checkbox"
              required
              aria-describedby="final-cta-consent-error"
            />
            <label class="final-cta__consent-label" for="final-cta-consent">
              Давам съгласието си съобразно новите правила за <span
                class="final-cta__consent-link">защита на личните данни</span>
            </label>
          </div>
          <span class="final-cta__error" id="final-cta-consent-error" aria-live="polite"></span>

          <button type="submit" class="final-cta__submit">Запиши се сега</button>
          <p class="final-cta__status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-block: 7em 6.94em; /* 112px top / 111px bottom */
  }

  /* Background photo — full-width, behind everything */
  .final-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .final-cta__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      119.31deg,
      rgba(165, 196, 214, 0.85) 12.11%,
      rgba(249, 221, 222, 0.85) 80.81%
    );
  }

  .final-cta__inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    gap: 2em; /* 32px */
  }

  /* ---- Left: event details card ---- */
  .final-cta__details-card {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    padding: 5em 2.625em 2.625em; /* 80px 42px 42px */
    border: 2px solid var(--color-bg-white);
    border-radius: 1.875em; /* 30px */
    background-image: linear-gradient(
      to left,
      rgba(255, 255, 255, 0.07) 1.76%,
      rgba(255, 255, 255, 0.04) 98.47%
    );
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
  }

  .final-cta__header {
    display: flex;
    flex-direction: column;
    gap: 2em; /* 32px */
  }
  .final-cta__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2.625em; /* 42px */
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  /* Line break after "Направи" — mobile only. */
  .final-cta__title-break {
    display: none;
  }
  .final-cta__accent {
    margin: 0;
  }

  .final-cta__details {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    padding: 1em 1.25em; /* 16px 20px */
    border-radius: 0.75em; /* 12px */
  }
  .final-cta__detail-row {
    display: flex;
    align-items: center;
    gap: 1.108em; /* 17.727px */
  }
  .final-cta__detail-icon {
    width: 2.25em; /* 36px */
    height: 2.25em;
    flex-shrink: 0;
  }
  .final-cta__detail-text {
    display: flex;
    flex-direction: column;
    line-height: 1.5;
  }
  .final-cta__detail-label {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    color: var(--color-text-secondary);
  }
  .final-cta__detail-value {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.25em; /* 20px */
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  /* Remaining tickets badge — absolutely positioned over top-right of card */
  .final-cta__tickets {
    position: absolute;
    top: -3.125em; /* -50px */
    left: 26.625em; /* 426px */
    width: 9.0625em; /* 145px */
    height: 7.625em; /* 122px */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .final-cta__tickets-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1.5em 2.311em; /* 24px 36.975px (relative to base, not the digit) */
    line-height: 1;
    white-space: nowrap;
    border: 1px solid var(--color-primary);
    border-radius: 1.733em; /* 27.731px */
    background-image: linear-gradient(
      -90deg,
      rgb(165, 196, 214) 16.83%,
      rgb(252, 235, 236) 40.81%
    );
    box-shadow: 0px 0px 9.244px 3.697px rgba(169, 8, 49, 0.2);
  }
  .final-cta__tickets-digit {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 4.625em; /* 74px */
    line-height: 1;
    color: var(--color-text-primary);
  }
  .final-cta__tickets-tag {
    position: absolute;
    top: -1.6875em; /* -27px */
    left: 1.1875em; /* 19px */
    width: 6.6875em; /* 107px */
    height: 2.75em; /* 44px */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.3465em 0.693em; /* 5.546px 11.092px */
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1;
    text-align: center;
    color: var(--color-text-white);
    background-color: var(--color-primary);
    border-radius: 1.04em; /* 16.639px */
    box-shadow:
      0px 0px 9.244px 0px rgba(169, 8, 49, 0.2),
      0px 3.697px 7.58px 0px rgba(0, 0, 0, 0.15);
  }

  /* ---- Right: registration form card ---- */
  .final-cta__form-card {
    flex-shrink: 0;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 39.375em; /* 630px */
    padding: 3.5em 3.75em; /* 56px 60px */
    border: 1px solid var(--color-bg-white);
    border-radius: 1.875em; /* 30px */
    background-image: linear-gradient(
      -90deg,
      rgba(255, 255, 255, 0.42) 1.76%,
      rgba(255, 255, 255, 0.7) 98.47%
    );
    -webkit-backdrop-filter: blur(15px);
    backdrop-filter: blur(15px);
  }
  .final-cta__form {
    display: flex;
    flex-direction: column;
    gap: 3em; /* 48px */
    width: 100%;
  }
  .final-cta__fields {
    display: flex;
    flex-direction: column;
    gap: 1.25em; /* 20px */
    width: 100%;
  }
  .final-cta__field {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
    width: 100%;
  }
  .final-cta__label {
    padding-left: 1em; /* 16px */
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.875em; /* 14px */
    line-height: 1;
    color: var(--color-primary);
  }
  .final-cta__input {
    width: 100%;
    padding: 0.875em 1em; /* 14px 16px */
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1em; /* 16px */
    line-height: 1.5;
    color: var(--color-text-primary);
    background-color: var(--color-bg-white);
    border: none;
    border-radius: 1.5em; /* 24px */
  }
  .final-cta__input::placeholder {
    color: var(--color-text-inactive);
    opacity: 1;
  }

  .final-cta__consent-section {
    display: flex;
    flex-direction: column;
    gap: 2em; /* 32px */
    width: 100%;
  }
  .final-cta__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.75em; /* 12px */
  }
  .final-cta__checkbox {
    flex-shrink: 0;
    width: 1em; /* 16px */
    height: 1em;
    margin-top: 0.25em; /* 4px top padding from design */
    accent-color: var(--color-primary);
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-primary);
    border-radius: 3px;
    box-shadow: 0px 3px 13.5px 0px rgba(0, 0, 0, 0.05);
    cursor: pointer;
  }
  .final-cta__consent-label {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.5;
    color: #484848;
    cursor: pointer;
  }
  .final-cta__consent-link {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .final-cta__submit {
    width: 100%;
    padding: 1.25em 2.25em; /* 20px 36px */
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1em; /* 16px */
    line-height: 1;
    text-align: center;
    color: var(--color-text-white);
    background-image: linear-gradient(to left, #880425, #a90931);
    border: none;
    border-radius: 2.0625em; /* 33px */
    box-shadow: 0px 5px 15px rgba(169, 8, 49, 0.4);
    cursor: pointer;
    transition: opacity var(--transition-base);
  }
  .final-cta__submit:hover {
    opacity: 0.9;
  }
  .final-cta__submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .final-cta__input[aria-invalid="true"] {
    border-color: #c0143c;
    outline-color: #c0143c;
  }

  .final-cta__error {
    display: none;
    margin-top: 0.4em;
    font-family: var(--font-body);
    font-size: 0.8125em; /* 13px */
    line-height: 1.3;
    color: #c0143c;
  }
  .final-cta__error:not(:empty) {
    display: block;
  }

  .final-cta__status {
    margin-top: 0.75em;
    font-family: var(--font-body);
    font-size: 0.9375em; /* 15px */
    line-height: 1.4;
    text-align: center;
  }
  .final-cta__status:empty {
    display: none;
  }
  .final-cta__status[data-state="ok"] {
    color: var(--color-primary);
  }
  .final-cta__status[data-state="error"] {
    color: #c0143c;
  }

  /* ---- Tablet ---- */
  @media (max-width: 991px) {
    .final-cta {
      padding-block: 4em;
    }
    .final-cta__inner {
      flex-direction: column;
      gap: 4em; /* room for the badge that overhangs the top */
    }
    .final-cta__details-card {
      width: 100%;
    }
    .final-cta__form-card {
      width: 100%;
      align-self: auto;
    }
    /* Pull the ticket badge inside on stacked layout */
    .final-cta__tickets {
      left: auto;
      right: 1.5em;
      top: -3.125em;
    }
  }

  /* ---- Mobile landscape ---- */
  @media (max-width: 767px) {
    .final-cta {
      padding-block: 4em 3.5em; /* 64px / 56px */
    }
    /* single column, cards full-width, 16px gap; badge overlaps card top-right */
    .final-cta__inner {
      gap: 1em; /* 16px */
    }
    .final-cta__details-card {
      gap: 1.5em; /* 24px */
      padding: 1.5em; /* 24px all sides — badge overhangs above the card */
    }
    .final-cta__header {
      gap: 1em; /* 16px */
    }
    .final-cta__title {
      font-size: 1.75em; /* 28px */
    }
    .final-cta__title-break {
      display: inline;
    }
    /* rows sit flush inside the card on mobile (no inset box) */
    .final-cta__details {
      gap: 0.75em; /* 12px */
      padding: 0;
    }
    .final-cta__detail-row {
      gap: 0.5em; /* 8px */
    }
    .final-cta__detail-icon {
      width: 1.75em; /* 28px */
      height: 1.75em;
    }
    .final-cta__detail-label {
      font-size: 0.875em; /* 14px */
    }
    .final-cta__detail-value {
      font-size: 1em; /* 16px */
      white-space: normal;
    }
    .final-cta__form-card {
      padding: 2em 1.5em; /* 32px 24px */
    }
    .final-cta__form,
    .final-cta__consent-section {
      gap: 1.5em; /* 24px */
    }
    /* badge: top-right corner, overlapping the card top edge */
    .final-cta__tickets {
      top: -1.5em;
      left: auto;
      right: 1em;
      width: 5.375em; /* 86px */
      height: 4.524em; /* 72.36px */
    }
    .final-cta__tickets-number {
      padding: 0.89em 1.371em; /* 14.234px 21.93px */
      border-radius: 1.028em; /* 16.447px */
      box-shadow: 0px 0px 5.482px 2.193px rgba(169, 8, 49, 0.2);
    }
    .final-cta__tickets-digit {
      font-size: 2.743em; /* 43.89px */
    }
    .final-cta__tickets-tag {
      top: -1.4em;
      left: 0.25em;
      width: auto;
      height: auto;
      padding: 0.25em 0.3125em; /* 4px 5px */
      font-size: 0.75em; /* 12px */
      border-radius: 0.617em; /* 9.868px */
      box-shadow:
        0px 0px 5.482px 0px rgba(169, 8, 49, 0.2),
        0px 2.193px 4.496px 0px rgba(0, 0, 0, 0.15);
    }
    .final-cta__submit {
      min-height: 2.75em;
    }
    .final-cta__input {
      min-height: 2.75em;
    }
  }

  /* ---- Mobile portrait ---- */
  @media (max-width: 479px) {
    /* keep the badge from overflowing on the narrowest screens */
    .final-cta__tickets {
      right: 0.75em;
    }
  }
</style>

<script>
  const form = document.querySelector(".final-cta__form") as HTMLFormElement | null;
  const status = document.querySelector(".final-cta__status") as HTMLElement | null;
  const submit = form?.querySelector(".final-cta__submit") as HTMLButtonElement | null;

  if (form) {
    const fields = ["name", "phone", "email", "consent"] as const;
    type FieldName = (typeof fields)[number];

    const messages: Record<FieldName, string> = {
      name: "Моля, въведи името и фамилията си.",
      phone: "Моля, въведи валиден телефонен номер.",
      email: "Моля, въведи валиден имейл адрес.",
      consent: "Необходимо е съгласие, за да продължиш.",
    };

    const emailRe = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
    const phoneRe = /^[+\d][\d\s\-()]*$/;

    const field = (name: FieldName) =>
      form.elements.namedItem(name) as HTMLInputElement;

    const isValid = (name: FieldName): boolean => {
      const el = field(name);
      if (name === "consent") return el.checked;
      const v = (el.value || "").trim();
      if (name === "name") return v.length >= 2;
      if (name === "email") return emailRe.test(v);
      if (name === "phone") return phoneRe.test(v) && v.replace(/\D/g, "").length >= 6;
      return true;
    };

    const showError = (name: FieldName, show: boolean) => {
      const el = field(name);
      const err = document.getElementById(`final-cta-${name}-error`);
      if (show) {
        el.setAttribute("aria-invalid", "true");
        if (err) err.textContent = messages[name];
      } else {
        el.removeAttribute("aria-invalid");
        if (err) err.textContent = "";
      }
    };

    const validateField = (name: FieldName): boolean => {
      const valid = isValid(name);
      showError(name, !valid);
      return valid;
    };

    (["name", "phone", "email"] as FieldName[]).forEach((name) => {
      const el = field(name);
      el.addEventListener("blur", () => validateField(name));
      el.addEventListener("input", () => {
        if (el.getAttribute("aria-invalid")) validateField(name);
      });
    });
    field("consent").addEventListener("change", () => validateField("consent"));

    const setStatus = (msg: string, state: "ok" | "error" | "") => {
      if (!status) return;
      status.textContent = msg;
      status.dataset.state = state;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      let firstInvalid: HTMLElement | null = null;
      for (const name of fields) {
        if (!validateField(name) && !firstInvalid) firstInvalid = field(name);
      }
      if (firstInvalid) {
        setStatus("", "");
        firstInvalid.focus();
        return;
      }

      let attribution: Record<string, string> = {};
      try {
        attribution = JSON.parse(localStorage.getItem("h2u_attribution") || "{}");
      } catch {
        /* ignore */
      }

      const data = {
        name: field("name").value.trim(),
        phone: field("phone").value.trim(),
        email: field("email").value.trim(),
        consent: field("consent").checked,
        attribution, // fbclid / fbc / fbp / utm_* for offline conversion tracking
      };

      if (submit) submit.disabled = true;
      setStatus("Изпращане…", "");

      try {
        const res = await fetch("/api/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        const result = await res.json().catch(() => ({}));
        if (res.ok && result.ok) {
          form.reset();
          fields.forEach((n) => showError(n, false));
          setStatus("Пренасочване…", "ok");
          window.location.assign("/thank-you");
          return;
        }
        setStatus(result.error || "Възникна грешка при изпращането. Моля, опитай отново.", "error");
      } catch {
        setStatus("Няма връзка със сървъра. Провери интернет връзката и опитай отново.", "error");
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>
