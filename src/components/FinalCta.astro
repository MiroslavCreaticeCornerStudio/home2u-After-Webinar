---
// Final CTA Section — photo background + light pastel gradient overlay,
// event details glass card.
// Figma node 2856:555.
const details = [
  { icon: "icon-finalcta-date.svg", label: "Дати:", value: "08-15 септември" },
  { icon: "icon-finalcta-time.svg", label: "Час:", value: "17:00 - 18:30 ч." },
  { icon: "icon-finalcta-location.svg", label: "Място:", value: "Hilton Sofia" },
];
---

<section class="final-cta" id="register">
  <!-- Background photo (full-width) + gradient overlay -->
  <img
    class="final-cta__bg"
    src="/course/assets/images/finalcta-background.jpg"
    alt=""
    aria-hidden="true"
    width="1920"
    height="1083"
    loading="lazy"
    decoding="async"
  />
  <span class="final-cta__overlay" aria-hidden="true"></span>

  <div class="final-cta__inner container container--padded">
    <!-- Left: event details card -->
    <div class="final-cta__details-card">
      <div class="final-cta__header">
        <h2 class="final-cta__title">
          Направи<br class="final-cta__title-break" /> първата крачка към сделките за милиони
        </h2>
        <hr class="accent-line final-cta__accent" />
      </div>

      <div class="final-cta__details">
        {
          details.map((item) => (
            <div class="final-cta__detail-row">
              <img
                src={`/course/assets/images/${item.icon}`}
                alt=""
                width="36"
                height="36"
                class="final-cta__detail-icon"
                loading="lazy"
              />
              <div class="final-cta__detail-text">
                <span class="final-cta__detail-label">{item.label}</span>
                <span class="final-cta__detail-value">{item.value}</span>
              </div>
            </div>
          ))
        }
      </div>

      <a href="#pricing" class="btn btn--primary final-cta__cta">Запази своето място</a>

      <div class="final-cta__tickets">
        <span class="final-cta__tickets-tag">Оставащи места</span>
        <span class="final-cta__tickets-number"><span class="final-cta__tickets-digit">10</span></span>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-block: 7em 6.94em;
  }

  /* Background photo — full-width, behind everything */
  .final-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .final-cta__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      119.31deg,
      rgba(165, 196, 214, 0.85) 12.11%,
      rgba(249, 221, 222, 0.85) 80.81%
    );
  }

  .final-cta__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    justify-content: center;
    gap: 2em;
  }

  /* ---- Left: event details card ---- */
  .final-cta__details-card {
    position: relative;
    flex: 0 1 38em;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1em;
    padding: 5em 2.625em 2.625em;
    border: 2px solid var(--color-bg-white);
    border-radius: 1.875em;
    background-image: linear-gradient(
      to left,
      rgba(255, 255, 255, 0.07) 1.76%,
      rgba(255, 255, 255, 0.04) 98.47%
    );
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
  }

  .final-cta__header {
    display: flex;
    flex-direction: column;
    gap: 2em;
  }
  .final-cta__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2.625em;
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .final-cta__title-break {
    display: none;
  }
  .final-cta__accent {
    margin: 0;
  }

  .final-cta__details {
    display: flex;
    flex-direction: column;
    gap: 1em;
    padding: 1em 1.25em;
    border-radius: 0.75em;
  }
  .final-cta__detail-row {
    display: flex;
    align-items: center;
    gap: 1.108em;
  }
  .final-cta__detail-icon {
    width: 2.25em;
    height: 2.25em;
    flex-shrink: 0;
  }
  .final-cta__detail-text {
    display: flex;
    flex-direction: column;
    line-height: 1.5;
  }
  .final-cta__detail-label {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em;
    color: var(--color-text-secondary);
  }
  .final-cta__detail-value {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 1.25em;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .final-cta__cta {
    width: 100%;
  }

  /* Remaining tickets badge — hidden, kept in HTML for easy re-enable */
  .final-cta__tickets {
    display: none;
    position: absolute;
    top: -3.125em;
    right: 2em;
    left: auto;
    width: 9.0625em;
    height: 7.625em;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .final-cta__tickets-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1.5em 2.311em;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid var(--color-primary);
    border-radius: 1.733em;
    background-image: linear-gradient(
      -90deg,
      rgb(165, 196, 214) 16.83%,
      rgb(252, 235, 236) 40.81%
    );
    box-shadow: 0px 0px 9.244px 3.697px rgba(169, 8, 49, 0.2);
  }
  .final-cta__tickets-digit {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 4.625em;
    line-height: 1;
    color: var(--color-text-primary);
  }
  .final-cta__tickets-tag {
    position: absolute;
    top: -1.6875em;
    left: 1.1875em;
    width: 6.6875em;
    height: 2.75em;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.3465em 0.693em;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.875em;
    line-height: 1;
    text-align: center;
    color: var(--color-text-white);
    background-color: var(--color-primary);
    border-radius: 1.04em;
    box-shadow:
      0px 0px 9.244px 0px rgba(169, 8, 49, 0.2),
      0px 3.697px 7.58px 0px rgba(0, 0, 0, 0.15);
  }

  /* ---- Tablet ---- */
  @media (max-width: 991px) {
    .final-cta {
      padding-block: 4em;
    }
    .final-cta__inner {
      flex-direction: column;
      gap: 4em;
    }
    .final-cta__details-card {
      width: 100%;
    }
    .final-cta__tickets {
      right: 1.5em;
    }
  }

  /* ---- Mobile landscape ---- */
  @media (max-width: 767px) {
    .final-cta {
      padding-block: 4em 3.5em;
    }
    .final-cta__inner {
      gap: 1em;
    }
    .final-cta__details-card {
      flex: none;
      gap: 1.5em;
      padding: 1.5em;
    }
    .final-cta__header {
      gap: 1em;
    }
    .final-cta__title {
      font-size: 1.75em;
    }
    .final-cta__title-break {
      display: inline;
    }
    .final-cta__details {
      gap: 0.75em;
      padding: 0;
    }
    .final-cta__detail-row {
      gap: 0.5em;
    }
    .final-cta__detail-icon {
      width: 1.75em;
      height: 1.75em;
    }
    .final-cta__detail-label {
      font-size: 0.875em;
    }
    .final-cta__detail-value {
      font-size: 1em;
      white-space: normal;
    }
    /* Badge on mobile */
    .final-cta__tickets {
      top: -1.5em;
      left: auto;
      right: 1em;
      width: 5.375em;
      height: 4.524em;
    }
    .final-cta__tickets-number {
      padding: 0.89em 1.371em;
      border-radius: 1.028em;
      box-shadow: 0px 0px 5.482px 2.193px rgba(169, 8, 49, 0.2);
    }
    .final-cta__tickets-digit {
      font-size: 2.743em;
    }
    .final-cta__tickets-tag {
      top: -1.4em;
      left: 0.25em;
      width: auto;
      height: auto;
      padding: 0.25em 0.3125em;
      font-size: 0.75em;
      border-radius: 0.617em;
    }
  }

  /* ---- Mobile portrait ---- */
  @media (max-width: 479px) {
    .final-cta__tickets {
      right: 0.75em;
    }
  }
</style>
