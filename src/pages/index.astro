---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TargetAudience from "../components/TargetAudience.astro";
import WhyJoin from "../components/WhyJoin.astro";
import WhatsIncluded from "../components/WhatsIncluded.astro";
import Speaker from "../components/Speaker.astro";
import Benefits from "../components/Benefits.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <a href="#register" class="sr-only">Към записването</a>
  <main>
    <Hero />
    <TargetAudience />
    <WhyJoin />
    {/* Shared cityscape backdrop spanning What's-included → Speaker (Figma node 2856:183) */}
    <div class="section-backdrop">
      <WhatsIncluded />
      <Speaker />
    </div>
    <Benefits />
    <Pricing />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Soft pastel cityscape backdrop (Figma 2723:619): dimmed cityscape under a
     blue→pink tint, fading to white at the top and bottom edges. */
  .section-backdrop {
    background-color: #ffffff;
    background-image:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 85%, #ffffff 100%),
      linear-gradient(180deg, #ffffff 0%, rgba(255, 255, 255, 0) 13.5%),
      linear-gradient(180deg, rgba(196, 211, 223, 0.9) 6%, rgba(241, 217, 222, 0.9) 100%),
      linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.4)),
      url("/assets/images/includes-speaker-bg.jpg");
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
  }
</style>
