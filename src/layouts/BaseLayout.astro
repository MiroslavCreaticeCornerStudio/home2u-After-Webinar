---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Home2U — Уебинар: Сделки за милиони от брокерство",
  description = "Онлайн уебинар с Ралица: научи как да правиш сделки за милиони от брокерство. Практически насоки, реални примери и стратегии за успех в имотния бизнес.",
  // TODO: replace with a purpose-built 1200×630 OG image; using an existing photo for now.
  ogImage = "/course/assets/images/finalcta-background.jpg",
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/course/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="bg_BG" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts — self-hosted brand font (Sharp Grotesk Cyr); @font-face in global.css. -->
    <link
      rel="preload"
      href="/course/assets/fonts/sharp-grotesk-cyr-medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/course/assets/fonts/sharp-grotesk-cyr-book.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <slot name="head" />

    <!-- Ad attribution capture (Facebook fbclid + UTMs) for offline conversion
         tracking. Persists last-touch attribution in localStorage so it survives
         navigation and is attached to the lead on form submit. -->
    <script is:inline>
      (function () {
        try {
          var KEY = "h2u_attribution";
          var TRACKED = ["fbclid", "utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"];
          var params = new URLSearchParams(location.search);
          var hasNew = TRACKED.some(function (p) { return params.get(p); });

          function readCookie(name) {
            var m = document.cookie.match("(?:^|; )" + name.replace(/([.*+?^${}()|[\]\\])/g, "\\$1") + "=([^;]*)");
            return m ? decodeURIComponent(m[1]) : "";
          }

          var data = {};
          try { data = JSON.parse(localStorage.getItem(KEY) || "{}"); } catch (e) {}

          if (hasNew) {
            // New ad click → refresh attribution (last-touch wins)
            var fresh = {};
            TRACKED.forEach(function (p) { var v = params.get(p); if (v) fresh[p] = v; });
            fresh.landing_page = location.origin + location.pathname;
            fresh.referrer = document.referrer || "";
            fresh.captured_at = new Date().toISOString();
            if (fresh.fbclid) fresh.fbc = "fb.1." + Date.now() + "." + fresh.fbclid; // Meta CAPI format
            data = fresh;
          }

          // Prefer Meta Pixel cookies when present (better match quality)
          var fbp = readCookie("_fbp"); if (fbp) data.fbp = fbp;
          var fbc = readCookie("_fbc"); if (fbc) data.fbc = fbc;

          if (hasNew || fbp || fbc) localStorage.setItem(KEY, JSON.stringify(data));
        } catch (e) {}
      })();
    </script>

    <!-- Light GSAP scroll-reveal: soft fade-up + stagger as sections enter view.
         Pre-hidden before paint (no flash); respects prefers-reduced-motion;
         falls back to fully-visible if GSAP fails to load. -->
    <script is:inline>
      (function () {
        if (!window.matchMedia || !matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.documentElement.classList.add("gsap-reveal");
        }
        // Safety net: if GSAP never loads, reveal everything.
        setTimeout(function () {
          if (!window.gsap) document.documentElement.classList.remove("gsap-reveal");
        }, 2500);
      })();
    </script>
    <style is:inline>
      html.gsap-reveal
        :is(
          .hero__headline, .hero__card, .hero__info-card,
          .ta__intro, .ta__row,
          .why-join__heading, .why-join__text, .why-join__item, .why-join__visual,
          .wi__intro, .wi__card, .wi__detail,
          .speaker__photo, .speaker__details,
          .benefits__col,
          .pricing__head, .pricing__card,
          .faq__item,
          .final-cta__details-card, .final-cta__form-card,
          .footer__col
        ) {
        opacity: 0;
        will-change: opacity, transform;
      }
    </style>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var html = document.documentElement;
        var SEL =
          ".hero__headline, .hero__card, .hero__info-card," +
          ".ta__intro, .ta__row," +
          ".why-join__heading, .why-join__text, .why-join__item, .why-join__visual," +
          ".wi__intro, .wi__card, .wi__detail," +
          ".speaker__photo, .speaker__details," +
          ".benefits__col," +
          ".pricing__head, .pricing__card," +
          ".faq__item," +
          ".final-cta__details-card, .final-cta__form-card," +
          ".footer__col";

        function showAll() {
          html.classList.remove("gsap-reveal"); // drop the pre-hide → everything visible
        }

        if (!html.classList.contains("gsap-reveal")) return; // reduced motion: already visible
        if (!window.gsap || !window.ScrollTrigger) return void showAll();

        var gsap = window.gsap;
        var ST = window.ScrollTrigger;

        // Probe requestAnimationFrame. If it isn't running (headless / throttled),
        // tweens can't progress — just reveal everything instantly, never hide.
        var rafOK = false;
        requestAnimationFrame(function () { rafOK = true; });
        setTimeout(function () {
          if (!rafOK) return void showAll();

          gsap.registerPlugin(ST);
          gsap.set(SEL, { y: 24 }); // opacity already 0 via the pre-hide CSS
          var revealVars = {
            opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
            stagger: 0.08, overwrite: true, clearProps: "willChange",
          };
          function reveal(els) { gsap.to(els, revealVars); }

          ST.batch(SEL, { start: "top 88%", onEnter: reveal });

          // batch onEnter doesn't fire for elements already in view on load.
          requestAnimationFrame(function () {
            var vh = window.innerHeight;
            var inView = gsap.utils.toArray(SEL).filter(function (el) {
              var r = el.getBoundingClientRect();
              return r.top < vh * 0.9 && r.bottom > 0;
            });
            if (inView.length) reveal(inView);
          });

          if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(function () { ST.refresh(); });
          }

          // Safety net: never leave on-screen content hidden.
          setTimeout(function () {
            gsap.utils.toArray(SEL).forEach(function (el) {
              if (
                parseFloat(getComputedStyle(el).opacity) < 0.05 &&
                el.getBoundingClientRect().top < window.innerHeight
              ) {
                gsap.set(el, { opacity: 1, y: 0 });
              }
            });
          }, 4000);
        }, 150);
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
